ARG BASE_VERSION=15
ARG PG_VERSION=17

# Builder stage — compile pgvector from FreeBSD ports
FROM ghcr.io/daemonless/base:${BASE_VERSION} AS builder
ARG PG_VERSION

RUN pkg update && pkg install -y \
    postgresql${PG_VERSION}-server \
    FreeBSD-bmake FreeBSD-clibs-dev FreeBSD-clang FreeBSD-clang-dev FreeBSD-toolchain \
    gmake pkgconf && \
    pkg clean -ay && rm -rf /var/cache/pkg/* /var/db/pkg/repos/*

RUN fetch -qo /tmp/ports.tar.zst \
    "https://download.freebsd.org/ports/ports/ports.tar.zst" && \
    mkdir -p /usr/ports && \
    tar -xf /tmp/ports.tar.zst -C /usr/ports --strip-components=1 \
        ports/databases/pgvector ports/Mk ports/Templates ports/Keywords && \
    rm /tmp/ports.tar.zst && \
    cd /usr/ports/databases/pgvector && \
    make DEFAULT_VERSIONS+=pgsql=${PG_VERSION} BATCH=yes install clean && \
    pkg create -o /tmp postgresql${PG_VERSION}-pgvector && \
    rm -rf /usr/ports

# Production image
FROM ghcr.io/daemonless/base:${BASE_VERSION}
ARG PG_VERSION

ARG FREEBSD_ARCH=amd64
ARG PACKAGES="postgresql${PG_VERSION}-server postgresql${PG_VERSION}-client postgresql${PG_VERSION}-contrib"
ARG UPSTREAM_URL="https://www.postgresql.org/docs/release/"

# --- Metadata (Injected by Generator) ---
LABEL org.opencontainers.image.title="{{ title }} ${PG_VERSION}" \
      org.opencontainers.image.description="{{ description }}" \
      org.opencontainers.image.source="{{ repo_url }}" \
      org.opencontainers.image.url="{{ web_url }}" \
      org.opencontainers.image.documentation="https://www.postgresql.org/docs/${PG_VERSION}/" \
      org.opencontainers.image.licenses="PostgreSQL" \
      org.opencontainers.image.vendor="daemonless" \
      org.opencontainers.image.authors="daemonless" \
      io.daemonless.category="{{ category }}" \
{%- if ports %}
      io.daemonless.port="{{ ports[0].port }}" \
{%- endif %}
{%- if volumes %}
      io.daemonless.volumes="{{ volumes | map(attribute='path') | join(',') }}" \
{%- endif %}
{%- if mlock %}
      org.freebsd.jail.allow.mlock="required" \
{%- endif %}
      org.freebsd.jail.allow.sysvipc="required" \
      io.daemonless.arch="${FREEBSD_ARCH}" \
      io.daemonless.pkg-source="pkg" \
      io.daemonless.upstream-url="${UPSTREAM_URL}" \
      io.daemonless.packages="${PACKAGES}"

# Install PostgreSQL
RUN pkg update && \
    pkg install -y ${PACKAGES} && \
    pkg clean -ay && \
    rm -rf /var/cache/pkg/* /var/db/pkg/repos/*

# Install pgvector package built from ports in builder stage
COPY --from=builder /tmp/postgresql${PG_VERSION}-pgvector-*.pkg /tmp/pgvector.pkg
RUN pkg add /tmp/pgvector.pkg && rm /tmp/pgvector.pkg

# Create directories (use Linux-compatible paths for drop-in replacement)
RUN mkdir -p /var/lib/postgresql/data /var/run/postgresql /run/secrets /docker-entrypoint-initdb.d && \
    chmod 755 /var/lib && \
    chown -R bsd:bsd /var/lib/postgresql /var/run/postgresql /run/secrets /docker-entrypoint-initdb.d

# Copy service definitions and init scripts
COPY root/ /

# Make scripts executable
RUN chmod +x /etc/services.d/*/run /etc/cont-init.d/* /healthz 2>/dev/null || true

# Store PG version for scripts
RUN mkdir -p /var/db/postgres && echo "${PG_VERSION}" > /var/db/postgres/pg_version

# Extract package version for tagging (e.g., 17.7_1 or 14.20_1)
RUN mkdir -p /app && \
    pkg query '%v' postgresql${PG_VERSION}-server > /app/version

ENV PGDATA="/var/lib/postgresql/data" \
    PG_VERSION="${PG_VERSION}" \
    POSTGRES_USER="postgres" \
    POSTGRES_PASSWORD="" \
    POSTGRES_DB="postgres" \
    POSTGRES_INITDB_ARGS="" \
    POSTGRES_HOST_AUTH_METHOD="scram-sha-256"

STOPSIGNAL SIGINT

# --- Expose (Injected by Generator) ---
{%- if ports %}
EXPOSE {{ ports | map(attribute='port') | join(' ') }}
{%- endif %}

# --- Volumes (Injected by Generator) ---
{%- if volumes %}
VOLUME {{ volumes | map(attribute='path') | join(' ') }}
{%- endif %}
